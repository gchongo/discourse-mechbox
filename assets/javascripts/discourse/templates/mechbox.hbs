<section class="mechbox__page">
  <header class="mechbox__header">
    <h1>{{i18n "mechbox.title"}}</h1>
    <p class="mechbox__disclaimer">{{i18n "mechbox.disclaimer"}}</p>
  </header>

  {{#if this.errorMessage}}
    <div class="alert alert-error">
      {{this.errorMessage}}
    </div>
  {{/if}}

  <div class="mechbox__grid">
    <aside class="mechbox__tools-panel">
      <h2>{{i18n "mechbox.tools_title"}}</h2>
      {{#if this.hasBuiltinTools}}
        <ul class="mechbox__tool-list">
          {{#each this.builtinTools as |tool|}}
            <li>
              <button
                type="button"
                class="btn btn-flat mechbox__tool-btn {{if (this.isSelectedTool tool.tool_id) "is-active"}}"
                {{on "click" (fn this.selectTool tool.tool_id)}}
              >
                <span>{{tool.name}}</span>
              </button>
              <button
                type="button"
                class="btn btn-icon"
                title={{i18n "mechbox.favorite_toggle_title"}}
                disabled={{this.isRefreshing}}
                {{on "click" (fn this.toggleFavorite tool.tool_id)}}
              >
                {{#if (this.isFavorited tool.tool_id)}}★{{else}}☆{{/if}}
              </button>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p>{{i18n "mechbox.no_builtin_tools"}}</p>
      {{/if}}
    </aside>

    <main class="mechbox__workbench-panel">
      <h2>{{i18n "mechbox.workbench_title"}}</h2>
      {{#if this.selectedTool}}
        <p class="mechbox__tool-description">{{this.selectedTool.description}}</p>
      {{/if}}
      <label for="mechbox-inputs">{{i18n "mechbox.inputs_label"}}</label>
      <textarea
        id="mechbox-inputs"
        class="mechbox__inputs"
        rows="10"
        value={{this.inputsJson}}
        {{on "input" this.updateInputs}}
      ></textarea>
      <div class="mechbox__actions">
        <button
          type="button"
          class="btn btn-primary"
          disabled={{this.isCalculating}}
          {{on "click" this.calculate}}
        >
          {{#if this.isCalculating}}
            {{i18n "mechbox.calculating"}}
          {{else}}
            {{i18n "mechbox.calculate"}}
          {{/if}}
        </button>
      </div>
      {{#if this.calculationResult}}
        <h3>{{i18n "mechbox.result_title"}}</h3>
        <pre class="mechbox__result">{{this.calculationResultJson}}</pre>
      {{/if}}
    </main>

    <section class="mechbox__records-panel">
      <h2>{{i18n "mechbox.records_title"}}</h2>
      {{#if this.records.length}}
        <ul class="mechbox__record-list">
          {{#each this.records as |record|}}
            <li>
              <strong>{{record.title}}</strong>
              <span>{{record.tool_id}}</span>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p>{{i18n "mechbox.no_records"}}</p>
      {{/if}}
    </section>
  </div>
</section>
